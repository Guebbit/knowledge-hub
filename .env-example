# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your Linux username — used to mount the shared ~/.ollama model directory.
LINUX_USERNAME=your-username
# Container runtime: docker | podman
CONTAINER_ENGINE=podman
# Directory where LLM files not managed by ollama (ex: Whisper) are stored on the host machine
MODELS_PATH=~/.models


# ── PRESETS ───────────────────────────────────────────────────────────────────
# Each preset is a provider:model pair. Define as many as you want.
# Format: PRESET_<NAME>=provider:model
#   provider: ollama | anthropic | openai | claude-code
#   model:    any model name valid for that provider
#
# claude-code routes through the `claude` CLI (claude -p) instead of the
# Anthropic API — it uses your existing Claude Code login/subscription, no
# ANTHROPIC_API_KEY needed. Slower per call (spawns a CLI process each time).
# Not usable for REPO_PRESET_GRAPH/REPO_PRESET_WIKI — graphify talks to the
# API directly and has no CLI backend.
#
# Usage: 2brain "topic" --preset deep
#        2brain "topic"              ← uses DEFAULT_PRESET

# Which preset to use when no --preset flag is passed
DEFAULT_PRESET=fast

# fast: local Ollama — free, offline, no API key. The default and the fallback
#       used automatically when a cloud preset's credential is missing.
# deep: a capable cloud model for dense/important jobs.
PRESET_FAST=ollama:qwen3:8b
# PRESET_FAST=openai:gpt-4o-mini
# PRESET_FAST=anthropic:claude-sonnet-4-6
# PRESET_FAST=claude-code:sonnet
# PRESET_DEEP=openai:gpt-4o
PRESET_DEEP=ollama:qwen3.6:27b


# ── API KEYS ──────────────────────────────────────────────────────────────────
# Only needed when using a preset that points to that provider
# ANTHROPIC_API_KEY=sk-ant-...
# GitHub Models (free tier via GitHub PAT — get token at github.com/settings/tokens)
# OPENAI_API_KEY=ghp_your_github_pat_here
OPENAI_BASE_URL=https://models.inference.ai.azure.com # Github pro with openai models
# OPENAI_BASE_URL=https://api.openai.com/v1"            # True openai

# ── PORTS ─────────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434/v1


# ── OLLAMA SERVER ─────────────────────────────────────────────────────────────
# How long a loaded model stays in VRAM when idle. Format: 5m, 1h, 0 (never unload).
OLLAMA_KEEP_ALIVE=5m
# Context window size in tokens. Smaller = less VRAM, faster generation.
OLLAMA_NUM_CTX=32000
# Seconds to wait for a response. Large models on hybrid GPU/CPU can be slow.
OLLAMA_TIMEOUT=600
# CPU threads. Keep low to leave headroom for other processes.
OLLAMA_NUM_THREAD=1

# Seconds to wait for `claude -p` when using a claude-code preset.
#CLAUDE_CODE_TIMEOUT=600


# ── OLLAMA RESOURCES (container limits) ───────────────────────────────────────
OLLAMA_MEM_LIMIT=16g
OLLAMA_SHM_SIZE=8g
OLLAMA_CPUS=8.0


# ── AUDIO TRANSCRIPTION ───────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
# Larger = more accurate, slower, more VRAM. base is a good default.
WHISPER_MODEL=base


# ── 2REPO ─────────────────────────────────────────────────────────────────────
# Preset used by graphify for semantic enrichment (must reference a PRESET_* above).
# The provider is mapped to graphify's --backend: anthropic→claude, openai→openai, ollama→ollama.
REPO_PRESET_GRAPH=deep
# Preset used for wiki page generation (2repo wiki). Falls back to REPO_PRESET_GRAPH.
#REPO_PRESET_WIKI=fast
# Optional default integration target: claude | copilot | cursor | neutral
#REPO_AI_TARGET=neutral
# Warn when this many files changed since last graph generation baseline (0 disables warnings).
REPO_STALE_THRESHOLD=5
# Set to 1 before `2repo hook .` to auto-refresh the wiki after each commit.
#REPO_WIKI_AUTO=1
