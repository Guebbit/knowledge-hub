# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your Linux username — used to mount the shared ~/.ollama model directory.
LINUX_USERNAME=your-username-here
# Container runtime: docker | podman
CONTAINER_ENGINE=docker


# ── PRESETS ───────────────────────────────────────────────────────────────────
# Each preset is a provider:model pair. Define as many as you want.
# Format: PRESET_<NAME>=provider:model
#   provider: ollama | anthropic | openai
#   model:    any model name valid for that provider
#
# Usage: 2brain "topic" --preset smart
#        2brain "topic"              ← uses DEFAULT_PRESET

# Which preset to use when no --preset flag is passed
DEFAULT_PRESET=local

PRESET_LOCAL=ollama:qwen3.6:27B
PRESET_BIG=ollama:qwen3.6:27B
PRESET_SMART=anthropic:claude-sonnet-4-6
PRESET_CHEAP=openai:gpt-4o-mini


# ── API KEYS ──────────────────────────────────────────────────────────────────
# Only needed when using a preset that points to that provider
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...


# ── PORTS ─────────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
# WIKI_MCP_PORT=8888
# GRAPHIFY_PORT=8889


# ── OLLAMA SERVER ─────────────────────────────────────────────────────────────
# How long a loaded model stays in VRAM when idle. Format: 5m, 1h, 0 (never unload).
OLLAMA_KEEP_ALIVE=5m
# Context window size in tokens. Smaller = less VRAM, faster generation.
OLLAMA_NUM_CTX=32000
# Seconds to wait for a response. Large models on hybrid GPU/CPU can be slow.
OLLAMA_TIMEOUT=600
# CPU threads. Keep low to leave headroom for other processes.
OLLAMA_NUM_THREAD=1


# ── OLLAMA RESOURCES (container limits) ───────────────────────────────────────
OLLAMA_MEM_LIMIT=16g
OLLAMA_SHM_SIZE=8g
OLLAMA_CPUS=8.0


# ── AUDIO TRANSCRIPTION ───────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
# Larger = more accurate, slower, more VRAM. base is a good default.
WHISPER_MODEL=base
MODELS_PATH=/models
